rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function validCoordinate(value, minimum, maximum) {
      return value is number && value >= minimum && value <= maximum;
    }

    function validCoordinates(data, allowEmpty) {
      return (allowEmpty && data.lat == '' && data.lng == '')
        || (validCoordinate(data.lat, -90, 90) && validCoordinate(data.lng, -180, 180));
    }

    function validTagValues(tags) {
      return tags is list && tags.size() <= 20;
    }

    function validOptionalString(data, field, maximum) {
      return data.get(field, '') is string && data.get(field, '').size() <= maximum;
    }

    function validImportWarnings(warnings) {
      return warnings is list && warnings.size() <= 5
        && warnings.toSet().hasOnly(['MISSING_COORDINATES', 'AMBIGUOUS_MATCH', 'APPROXIMATE_COORDINATES', 'METADATA_ONLY', 'LOCAL_FALLBACK']);
    }

    function validImportAcknowledgements(warnings) {
      return warnings is list && warnings.size() <= 2
        && warnings.toSet().hasOnly(['AMBIGUOUS_MATCH', 'APPROXIMATE_COORDINATES']);
    }

    function validImportQuality(quality) {
      return quality is map
        && quality.keys().hasAll(['confidence', 'coordinateQuality', 'provenance', 'warnings', 'ambiguity', 'verified'])
        && quality.keys().hasOnly(['confidence', 'coordinateQuality', 'provenance', 'warnings', 'ambiguity', 'verified'])
        && quality.confidence in ['high', 'medium', 'low']
        && quality.coordinateQuality in ['exact', 'geocoded', 'approximate', 'missing']
        && quality.provenance in ['official_api', 'geocoder', 'metadata', 'local_parser', 'place_search']
        && validImportWarnings(quality.warnings)
        && quality.ambiguity is bool
        && quality.verified is bool;
    }

    function validImportSource(source) {
      return source is map
        && source.keys().hasAll(['provider', 'inputUrl', 'canonicalUrl', 'resolvedUrl', 'providerId'])
        && source.keys().hasOnly(['provider', 'inputUrl', 'canonicalUrl', 'resolvedUrl', 'providerId'])
        && source.provider is string && source.provider.size() <= 128
        && source.inputUrl is string && source.inputUrl.size() <= 2048
        && source.canonicalUrl is string && source.canonicalUrl.size() <= 2048
        && source.resolvedUrl is string && source.resolvedUrl.size() <= 2048
        && source.providerId is string && source.providerId.size() <= 256;
    }

    function validImportDuplicate(duplicate) {
      return duplicate is map
        && duplicate.keys().hasAll(['status', 'matchedCollection', 'matchedId', 'reasons'])
        && duplicate.keys().hasOnly(['status', 'matchedCollection', 'matchedId', 'reasons'])
        && duplicate.status in ['unchecked', 'none', 'possible', 'probable']
        && (duplicate.matchedCollection == null || duplicate.matchedCollection in ['saved', 'inbox'])
        && (duplicate.matchedId == null || (duplicate.matchedId is string && duplicate.matchedId.size() <= 256))
        && duplicate.reasons is list && duplicate.reasons.size() <= 4
        && duplicate.reasons.toSet().hasOnly(['providerPlaceId', 'sourceUrl', 'nearbyName', 'addressName']);
    }

    function validImportMetadata(data) {
      let fields = ['importQuality', 'importWarnings', 'importAcknowledgedWarnings', 'importSource', 'importDuplicate'];
      return !data.keys().hasAny(fields)
        || (data.keys().hasAll(fields)
          && validImportQuality(data.importQuality)
          && validImportWarnings(data.importWarnings)
          && validImportAcknowledgements(data.importAcknowledgedWarnings)
          && validImportSource(data.importSource)
          && validImportDuplicate(data.importDuplicate));
    }

    function validCommonFields(data, titleField, allowEmptyCoordinates) {
      return data[titleField] is string && data[titleField].size() > 0 && data[titleField].size() <= 180
        && data.address is string && data.address.size() <= 360
        && data.zone is string && data.zone.size() <= 120
        && validCoordinates(data, allowEmptyCoordinates)
        && data.category in ['bar', 'restaurant', 'cafe', 'bakery', 'market', 'other']
        && validTagValues(data.tags)
        && data.rating is number && data.rating >= 0 && data.rating <= 5
        && data.sourceType in ['google', 'apple', 'instagram', 'tripadvisor', 'manual']
        && validOptionalString(data, 'sourceUrl', 2048)
        && validOptionalString(data, 'resolvedUrl', 2048)
        && validOptionalString(data, 'providerPlaceId', 256)
        && validOptionalString(data, 'providerType', 128)
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function placeFields() {
      return ['name', 'address', 'zone', 'lat', 'lng', 'category', 'tags', 'rating', 'status', 'sourceType', 'sourceUrl', 'resolvedUrl', 'providerPlaceId', 'providerType', 'createdAt', 'updatedAt'];
    }

    function inboxFields() {
      return ['title', 'address', 'zone', 'lat', 'lng', 'category', 'tags', 'rating', 'sourceType', 'sourceUrl', 'resolvedUrl', 'providerPlaceId', 'providerType', 'importQuality', 'importWarnings', 'importAcknowledgedWarnings', 'importSource', 'importDuplicate', 'createdAt', 'updatedAt'];
    }

    function validPlace(data) {
      return data.keys().hasAll(['name', 'address', 'zone', 'lat', 'lng', 'category', 'tags', 'rating', 'status', 'sourceType', 'createdAt', 'updatedAt'])
        && data.keys().hasOnly(placeFields())
        && validCommonFields(data, 'name', false)
        && data.status in ['wishlist', 'visited', 'favorite', 'discarded'];
    }

    function validInbox(data) {
      return data.keys().hasAll(['title', 'address', 'zone', 'lat', 'lng', 'category', 'tags', 'rating', 'sourceType', 'createdAt', 'updatedAt'])
        && data.keys().hasOnly(inboxFields())
        && validCommonFields(data, 'title', true)
        && validImportMetadata(data);
    }

    match /users/{userId}/places/{placeId} {
      allow read, delete: if isOwner(userId);
      allow create: if isOwner(userId) && validPlace(request.resource.data);
      allow update: if isOwner(userId)
        && validPlace(request.resource.data)
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    match /users/{userId}/inbox/{inboxId} {
      allow read, delete: if isOwner(userId);
      allow create: if isOwner(userId) && validInbox(request.resource.data);
      allow update: if isOwner(userId)
        && validInbox(request.resource.data)
        && request.resource.data.createdAt == resource.data.createdAt;
    }
  }
}
